{
  "FluxFlow": {
    "Composition": {
      "workflows": {
        "main": {
          "nodes": {
            "inbound": {
              "type": "mqtt.trigger",
              "resources": {
                "triggerSource": "memory"
              },
              "configuration": {
                "topicFilter": "devices/+/state",
                "boundedCapacity": 16
              }
            },
            "reply": {
              "type": "sample.mqtt.reply",
              "configuration": {
                "replyTopicSuffix": "/reply",
                "payloadPrefix": "ACK: "
              }
            },
            "outbound": {
              "type": "mqtt.publish",
              "resources": {
                "publisher": "memory"
              },
              "configuration": {
                "publishTimeoutMilliseconds": 1000,
                "boundedCapacity": 16
              }
            }
          },
          "links": [
            { "from": "inbound.Output", "to": "reply.Input" },
            { "from": "reply.Output", "to": "outbound.Input" }
          ]
        }
      }
    }
  }
}
