<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>FluxFlow.Components.Expressions</PackageId>
    <AssemblyName>FluxFlow.Components.Expressions</AssemblyName>
    <RootNamespace>FluxFlow.Components.Expressions</RootNamespace>
    <Version>2.0.0</Version>
    <Authors>FluxFlow contributors</Authors>
    <Description>Shared expression registration helpers for FluxFlow component packages.</Description>
    <PackageTags>workflow;dataflow;components;expressions</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>Breaking: now builds on the extracted FluxFlow.Mapping package (IFlowExpressionEngine, IFlowMapContextFactory, …) instead of FluxFlow.Engine — the shared expression-registration helpers are engine-free. Update usings from FluxFlow.Engine.Mapping to FluxFlow.Mapping.</PackageReleaseNotes>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\FluxFlow.Mapping\FluxFlow.Mapping.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>