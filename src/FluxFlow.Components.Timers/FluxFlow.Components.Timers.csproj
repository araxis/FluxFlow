<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>FluxFlow.Components.Timers</PackageId>
    <AssemblyName>FluxFlow.Components.Timers</AssemblyName>
    <RootNamespace>FluxFlow.Components.Timers</RootNamespace>
    <Version>3.1.0</Version>
    <Authors>FluxFlow contributors</Authors>
    <Description>Standalone timer nodes for FluxFlow: interval and cron-schedule sources plus delay, throttle, and debounce transforms over an injected TimeProvider, with broadcast output/error/event ports. No engine required.</Description>
    <PackageTags>workflow;dataflow;components;timers</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>Wires timer.interval and timer.schedule boundedCapacity into FluxFlow.Nodes bounded source output. Timer source loops now await bounded source output capacity while transform timer nodes keep their existing bounded input behavior.</PackageReleaseNotes>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\FluxFlow.Nodes\FluxFlow.Nodes.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
