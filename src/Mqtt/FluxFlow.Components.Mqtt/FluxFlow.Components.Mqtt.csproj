<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>FluxFlow.Components.Mqtt</PackageId>
    <AssemblyName>FluxFlow.Components.Mqtt</AssemblyName>
    <RootNamespace>FluxFlow.Components.Mqtt</RootNamespace>
    <Version>4.1.2</Version>
    <Authors>FluxFlow contributors</Authors>
    <Description>Standalone MQTT nodes for FluxFlow over small injected MQTT contracts: IMqttPublisher for publish, IMqttTriggerSource for trigger subscriptions, and optional IMqttClientHealthSource health. Includes trigger request/reply acknowledgement through a correlated response port. Broadcast output/error/event ports. No engine or concrete MQTT client required.</Description>
    <PackageTags>workflow;dataflow;components;mqtt</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>Hardens MQTT contract records by snapshotting user-property and health-attribute dictionaries, with null maps treated as empty.</PackageReleaseNotes>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\FluxFlow.Nodes\FluxFlow.Nodes.csproj" />
    <ProjectReference Include="..\..\FluxFlow.Components.RequestReply\FluxFlow.Components.RequestReply.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.Threading.Tasks.Dataflow" Version="9.0.4" NoWarn="NU1510" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
