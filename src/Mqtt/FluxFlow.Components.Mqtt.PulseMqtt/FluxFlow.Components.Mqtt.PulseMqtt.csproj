<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>FluxFlow.Components.Mqtt.PulseMqtt</PackageId>
    <AssemblyName>FluxFlow.Components.Mqtt.PulseMqtt</AssemblyName>
    <RootNamespace>FluxFlow.Components.Mqtt.PulseMqtt</RootNamespace>
    <Version>2.0.4</Version>
    <Authors>FluxFlow contributors</Authors>
    <Description>Pulse MQTT-backed adapter for FluxFlow MQTT components. Owns Pulse client creation, start/stop, broker transport configuration, Last Will setup, publish mapping, trigger subscriptions, and health events while implementing the client-library-neutral FluxFlow MQTT contracts.</Description>
    <PackageTags>workflow;dataflow;components;mqtt;pulsemqtt</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>Hardens MQTT adapter user-property mapping by treating null maps as empty and rejecting named null values with explicit argument validation.</PackageReleaseNotes>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\FluxFlow.Components.Mqtt\FluxFlow.Components.Mqtt.csproj" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="FluxFlow.Components.Mqtt.PulseMqtt.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.0" />
    <PackageReference Include="Pulse.Mqtt.Client" Version="2.5.0" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
