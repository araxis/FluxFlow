<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>FluxFlow.Components.Routing.Composition</PackageId>
    <AssemblyName>FluxFlow.Components.Routing.Composition</AssemblyName>
    <RootNamespace>FluxFlow.Components.Routing.Composition</RootNamespace>
    <Version>1.0.0</Version>
    <Authors>FluxFlow contributors</Authors>
    <Description>Optional FluxFlow.Composition registration helpers for standalone routing nodes over host-owned keyed selectors and clocks.</Description>
    <PackageTags>workflow;dataflow;components;routing;composition</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>Initial optional composition adapter for routing nodes. Registers flow.switch, flow.fork, flow.merge, flow.window, flow.correlation, and flow.join factories, binds existing routing options from composition configuration, and resolves keyed selector delegates plus optional keyed TimeProvider resources owned by the host.</PackageReleaseNotes>
    <RepositoryType>git</RepositoryType>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\FluxFlow.Components.Routing\FluxFlow.Components.Routing.csproj" />
    <ProjectReference Include="..\FluxFlow.Composition\FluxFlow.Composition.csproj" />
    <ProjectReference Include="..\FluxFlow.Composition.Hosting\FluxFlow.Composition.Hosting.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
