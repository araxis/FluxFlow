<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>FluxFlow.Components.Journal</PackageId>
    <AssemblyName>FluxFlow.Components.Journal</AssemblyName>
    <RootNamespace>FluxFlow.Components.Journal</RootNamespace>
    <Version>0.1.0-alpha.1</Version>
    <Authors>FluxFlow contributors</Authors>
    <Description>Reusable event journal contracts and in-memory store for FluxFlow.</Description>
    <PackageTags>workflow;dataflow;components;events;journal;store</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>Adds neutral journal records, queries, retention options, store abstraction, and in-memory store.</PackageReleaseNotes>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\FluxFlow.Engine\FluxFlow.Engine.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
