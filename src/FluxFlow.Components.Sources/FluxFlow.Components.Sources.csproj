<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>FluxFlow.Components.Sources</PackageId>
    <AssemblyName>FluxFlow.Components.Sources</AssemblyName>
    <RootNamespace>FluxFlow.Components.Sources</RootNamespace>
    <Version>3.0.0</Version>
    <Authors>FluxFlow contributors</Authors>
    <Description>Standalone deterministic source nodes for FluxFlow: generated and sequence emitters built as FlowSource&lt;T&gt; over an injected TimeProvider, with broadcast output/error/event ports. No engine required.</Description>
    <PackageTags>workflow;dataflow;components;sources</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>Rebuilt on the FluxFlow.Nodes kit: source.generated and source.sequence are FlowSource&lt;T&gt; sources (started via StartAsync, items minted as FlowMessage envelopes carrying a fresh correlation id) that time off the injected TimeProvider. The engine factories, module, registration extensions, ports, type constants, design-metadata provider, the definition-options reader, and the JSON item/string-to-Type resolution layer (SourcesComponentOptions) are removed; GeneratedSourceNode takes its options plus the already-materialized items, SequenceSourceNode takes its options, and both take a TimeProvider directly and depend only on FluxFlow.Nodes (runs without the engine).</PackageReleaseNotes>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\FluxFlow.Nodes\FluxFlow.Nodes.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
