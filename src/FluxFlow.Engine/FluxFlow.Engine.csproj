<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>FluxFlow.Engine</PackageId>
    <AssemblyName>FluxFlow.Engine</AssemblyName>
    <RootNamespace>FluxFlow.Engine</RootNamespace>
    <Version>1.2.0</Version>
    <Authors>FluxFlow contributors</Authors>
    <Description>Generic dataflow-based workflow engine for typed node graphs with phase-ordered lifecycle, host-provided expression routing, diagnostics, and host lifecycle support.</Description>
    <PackageTags>workflow;dataflow;pipeline;flow-engine;tpl</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>Adds a build-time expression compile seam: IFlowExpressionEngine.Compile&lt;T&gt; (default-implemented, non-breaking) returns an IFlowCompiledExpression&lt;T&gt; so expressions parse once at build time instead of per message. ExpressionFlowPredicate now compiles once, a new ExpressionFlowMapper mirrors it for mapping, and the engine's own conditional links compile once. Event channels now use the non-lossy fanout source instead of a lossy broadcast block.</PackageReleaseNotes>
    <PackageProjectUrl>https://github.com/araxis/FluxFlow</PackageProjectUrl>
    <RepositoryUrl>https://github.com/araxis/FluxFlow</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="10.0.7" />
    <!-- On net10 Dataflow ships inbox; keeping the explicit ref for net8/9 compat -->
    <PackageReference Include="System.Threading.Tasks.Dataflow" Version="9.0.4" NoWarn="NU1510" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
