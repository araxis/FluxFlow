<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>FluxFlow.Engine</PackageId>
    <AssemblyName>FluxFlow.Engine</AssemblyName>
    <RootNamespace>FluxFlow.Engine</RootNamespace>
    <Version>2.0.0</Version>
    <Authors>FluxFlow contributors</Authors>
    <Description>Generic dataflow-based workflow engine for typed node graphs with phase-ordered lifecycle, host-provided expression routing, diagnostics, and host lifecycle support.</Description>
    <PackageTags>workflow;dataflow;pipeline;flow-engine;tpl</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>Breaking: the expression/mapping abstraction (IFlowExpressionEngine, IFlowCompiledExpression, IFlowMapper, IFlowPredicate, FlowMapContext, IFlowMapContextFactory, and the Expression/Delegate mapper+predicate adapters) is extracted out of FluxFlow.Engine into the new leaf package FluxFlow.Mapping, under the FluxFlow.Mapping namespace; the engine now references that package. Update usings from FluxFlow.Engine.Mapping to FluxFlow.Mapping. The engine becomes an optional composition runtime in the standalone-node architecture (3.x line) — components no longer require it.</PackageReleaseNotes>
    <PackageProjectUrl>https://github.com/araxis/FluxFlow</PackageProjectUrl>
    <RepositoryUrl>https://github.com/araxis/FluxFlow</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="10.0.7" />
    <!-- On net10 Dataflow ships inbox; keeping the explicit ref for net8/9 compat -->
    <PackageReference Include="System.Threading.Tasks.Dataflow" Version="9.0.4" NoWarn="NU1510" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\FluxFlow.Mapping\FluxFlow.Mapping.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
