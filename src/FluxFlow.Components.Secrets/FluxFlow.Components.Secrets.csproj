<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>FluxFlow.Components.Secrets</PackageId>
    <AssemblyName>FluxFlow.Components.Secrets</AssemblyName>
    <RootNamespace>FluxFlow.Components.Secrets</RootNamespace>
    <Version>1.5.1</Version>
    <Authors>FluxFlow contributors</Authors>
    <Description>Reusable secret reference and resolution contracts for FluxFlow.</Description>
    <PackageTags>workflow;dataflow;components;secrets;security</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>Hardens keyed DI registration helper argument validation ordering for direct resolver and descriptor-provider overloads.</PackageReleaseNotes>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.7" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
