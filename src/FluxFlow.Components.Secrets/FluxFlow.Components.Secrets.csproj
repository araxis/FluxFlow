<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>FluxFlow.Components.Secrets</PackageId>
    <AssemblyName>FluxFlow.Components.Secrets</AssemblyName>
    <RootNamespace>FluxFlow.Components.Secrets</RootNamespace>
    <Version>1.2.5</Version>
    <Authors>FluxFlow contributors</Authors>
    <Description>Reusable secret reference and resolution contracts for FluxFlow.</Description>
    <PackageTags>workflow;dataflow;components;secrets;security</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>Secret diagnostics now report null record, reference, and option collection entries as structured invalid-secret diagnostics instead of surfacing null-reference failures.</PackageReleaseNotes>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
