<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>FluxFlow.Components.Storage.FileSystem</PackageId>
    <AssemblyName>FluxFlow.Components.Storage.FileSystem</AssemblyName>
    <RootNamespace>FluxFlow.Components.Storage.FileSystem</RootNamespace>
    <Version>3.0.0</Version>
    <Authors>FluxFlow contributors</Authors>
    <Description>File-system-backed storage adapter for FluxFlow storage components.</Description>
    <PackageTags>workflow;dataflow;components;storage;filesystem;files</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReleaseNotes>Rebuilt against FluxFlow.Components.Storage 3.0.0 as a file-system IStorageStore backend. The package remains a backend adapter consumed by host-owned store registration, not a workflow node composition package.</PackageReleaseNotes>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\FluxFlow.Components.Storage\FluxFlow.Components.Storage.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
